{
  "entryPoints": [
    "app/admin/topics/actions.ts",
    "app/actions.ts",
    "app/game/triviaAudioGenerator.ts",
    "src/lib/firebase.ts",
    "src/lib/firebase-admin.ts"
  ],
  "entryPointStrategy": "expand",
  "plugin": ["typedoc-plugin-markdown"],
